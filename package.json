{
  "name": "loom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs -p 3000 -H 0.0.0.0",
    "dev:raw": "next dev -p 3000 -H 0.0.0.0",
    "build": "node scripts/build.mjs",
    "start": "node scripts/start.mjs -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "node scripts/typecheck.mjs",
    "test:contracts": "tsx --test tests/app-store-assets.test.ts tests/ci-workflow.test.ts tests/globals-compatibility.test.ts tests/quiet-horizon-layout.test.tsx tests/loom-app-scripts.test.ts tests/typecheck-script.test.ts tests/runtime-roots.test.ts tests/knowledge-ingest.test.ts tests/knowledge-home-source-library.test.tsx tests/night-chrome-theme.test.ts tests/native-sidebar-source-row-fallback.test.ts tests/category-folder-row-behavior.test.ts",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm run typecheck && npm run build && LOOM_SMOKE_CHAT=1 npm run smoke",
    "status:buckets": "node scripts/status-buckets.mjs",
    "stage:bucket": "node scripts/stage-bucket.mjs",
    "research": "tsx scripts/research.ts",
    "ingest": "tsx scripts/ingest-knowledge.ts",
    "atlas": "tsx scripts/build-atlas.ts",
    "rag": "tsx scripts/build-rag-index.ts",
    "search": "tsx scripts/build-search-index.ts",
    "knowledge:prune": "node scripts/prune-generated-public.mjs",
    "knowledge:refresh": "npm run ingest && npm run search && npm run rag && npm run knowledge:prune",
    "batch": "tsx scripts/batch-process.ts",
    "index": "node scripts/pagefind-if-html.mjs .next/server/app public/pagefind",
    "icons": "node scripts/generate-icons.mjs",
    "app": "node scripts/build-install-loom-app.mjs auto",
    "app:user": "node scripts/build-install-loom-app.mjs user",
    "app:system": "node scripts/build-install-loom-app.mjs system",
    "app:clean": "node scripts/clean-loom-app-bundles.mjs",
    "app:package": "node scripts/package-loom-app.mjs",
    "app:archive": "npm run build && node scripts/build-static-export.mjs && node scripts/archive-loom-app.mjs",
    "app:archive:store": "npm run build && node scripts/build-static-export.mjs && node scripts/archive-loom-app.mjs --store",
    "app:export:store": "node scripts/export-loom-app-store.mjs",
    "app:check-project": "node scripts/check-loom-macos-project-files.mjs",
    "app:smoke": "node scripts/installed-app-smoke.mjs",
    "app:screenshots": "node scripts/app-store-screenshots.mjs",
    "app:preflight": "node scripts/app-store-preflight.mjs",
    "app:where": "node scripts/where-loom-app.mjs",
    "app:open": "if [ -d \"$HOME/Applications/Loom.app\" ]; then open \"$HOME/Applications/Loom.app\"; else open /Applications/Loom.app; fi"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@huggingface/transformers": "^4.0.1",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@next/mdx": "^15.5.15",
    "@swc/helpers": "0.5.15",
    "github-slugger": "^2.0.0",
    "katex": "^0.16.11",
    "marked": "^18.0.0",
    "marked-katex-extension": "^5.1.8",
    "mermaid": "^11.4.0",
    "minisearch": "^7.2.0",
    "next": "^15.5.15",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "rehype-katex": "^7.0.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^1.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "array.prototype.findlast": "^1.2.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.5.15",
    "pagefind": "^1.1.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5",
    "umap-js": "^1.4.0"
  }
}
